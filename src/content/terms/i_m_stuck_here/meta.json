{
  "term": "I'm Stuck Here",
  "categories": [
    "Informal",
    "Colloquial"
  ],
  "difficultyLevel": "3",
  "pronunciation": "/aɪm stʌk hɪr/",
  "partOfSpeech": "Expression",
  "englishDefinitions": [
    "I cannot leave this place.",
    "I am trapped, delayed, or forced to stay here."
  ],
  "persianTranslation": [
    "اینجا گیر افتاده‌ام",
    "نمی‌توانم از اینجا بروم",
    "مجبورم اینجا بمانم"
  ],
  "examples": [
    "My car won't start, so I'm stuck here.",
    "I'm stuck here at work until the meeting ends.",
    "The storm canceled all flights, and now I'm stuck here."
  ],
  "synonyms": [
    "I can't leave",
    "I'm trapped here",
    "I'm stranded here",
    "I have to stay here"
  ],
  "antonyms": [
    "I'm free to go",
    "I can leave",
    "I'm on my way"
  ]
}