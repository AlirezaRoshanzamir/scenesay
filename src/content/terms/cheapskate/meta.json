{
  "term": "cheapskate",
  "categories": [],
  "pronunciation": "/ˈt͡ʃipˌskeɪt/",
  "partOfSpeech": "Noun",
  "englishDefinitions": [
    "Someone who stingily avoids spending money.",
    "(by extension) Someone who does not give freely."
  ],
  "persianTranslation": [
    "کسی که از خرج کردن پول پرهیز می کند.",
