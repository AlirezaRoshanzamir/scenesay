  "englishDefinitions": [
    "To happen or arise unexpectedly.",
    "To be mentioned or discussed.",
    "To move upward or approach."
  ],
  "persianTranslation": [
    "پیش آمدن",
    "مطرح شدن",
    "بالا آمدن"
  ],
  "examples": [
    "Something urgent came up at work.",
    "Her name came up during the meeting.",
    "A new opportunity came up last week."
  ],
  "synonyms": [
    "arise",
    "occur",
    "appear"
  ],
  "antonyms": [
    "disappear",
    "go away"
  ]
