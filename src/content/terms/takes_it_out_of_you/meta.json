{
  "term": "Takes It Out Of You",
  "categories": [
    "Idiomatic expression",
    "Informal"
  ],
  "difficultyLevel": "5",
  "pronunciation": "/teɪks ɪt aʊt əv juː/",
  "partOfSpeech": "Idiom",
  "englishDefinitions": [
    "Causes you to feel very tired, weak, or exhausted."
  ],
  "persianTranslation": [
    "خیلی خسته‌ات می‌کند",
    "از پا درمی‌آورد",
    "جان آدم را می‌گیرد"
  ],
  "examples": [
    "That long hike really takes it out of you.",
    "Working two jobs takes it out of you.",
    "The heat has been taking it out of me all week."
  ],
  "synonyms": [
    "exhausts you",
    "wears you out",
    "drains you"
  ],
  "antonyms": [
    "energizes you",
    "refreshes you"
  ]
}