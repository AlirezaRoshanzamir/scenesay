{
  "term": "I Suppose",
  "categories": [
    "Formal",
    "Informal"
  ],
  "difficultyLevel": "3",
  "pronunciation": "/aɪ səˈpoʊz/",
  "partOfSpeech": "Phrase",
  "englishDefinitions": [
    "used to say that something is probably true or likely",
    "used to agree reluctantly or uncertainly"
  ],
  "persianTranslation": [
    "فکر می‌کنم",
    "گمان می‌کنم",
    "به‌نظرم"
  ],
  "examples": [
    "I suppose you're right.",
    "We can go now, I suppose.",
    "I suppose it will rain later."
  ],
  "synonyms": [
    "I think",
    "I guess",
    "presumably"
  ],
  "antonyms": [
    "I doubt",
    "certainly not"
  ]
}