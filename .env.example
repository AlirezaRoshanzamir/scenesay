# ──────────────────────────────────────────────
# Anthropic
# Get your key at https://console.anthropic.com
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────
# OpenAI
# Get your key at https://platform.openai.com
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────
# OpenSubtitles
# Register at https://www.opensubtitles.com and
# create an API consumer to get the API key.
# ──────────────────────────────────────────────
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=

# ──────────────────────────────────────────────
# HTTP/HTTPS Proxy (optional)
# Used by the OpenSubtitles client when set.
# Both uppercase and lowercase forms are read.
# ──────────────────────────────────────────────
# HTTP_PROXY=http://user:pass@proxy.host:8080
# HTTPS_PROXY=http://user:pass@proxy.host:8080
